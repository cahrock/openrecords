# Example environment variables for local development.
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then run docker compose up.
#
# The defaults below match the values used in dev. For production deployment,
# generate strong unique passwords and store them in your container
# orchestration's secret manager (AWS Secrets Manager, Kubernetes Secrets, etc.).

# PostgreSQL configuration
POSTGRES_DB=openrecords
POSTGRES_USER=openrecords
POSTGRES_PASSWORD=change_me_in_production

# pgAdmin configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_production